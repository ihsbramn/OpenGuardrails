# ==========================================
# OpenGuardrails Server — Environment Variables
# ==========================================
# Copy this file to .env and fill in values for your environment.
# All settings below have sensible defaults (see src/config/env.js).

# ---- Node ----
NODE_ENV=production
PORT=3000

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openguardrails

# ---- JWT / Auth ----
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h

# ---- CORS ----
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=*

# ---- Server ----
# Log level: debug, info, warning, error
LOG_LEVEL=info
# Max JSON body size, e.g. "10mb", "50mb"
MAX_REQUEST_SIZE_MB=10

# ---- Admin Seed ----
# Used by the seed script to create the initial admin account
ADMIN_EMAIL=admin@openguardrails.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Administrator

# ---- Demo User Seed ----
DEMO_EMAIL=user@openguardrails.com
DEMO_PASSWORD=demo123
DEMO_FULL_NAME=Demo User

# ---- PostgreSQL Pool ----
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
